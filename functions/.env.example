RATE_LIMIT_PER_MINUTE=100
TOKEN_TTL_DAYS=30
USAGE_TTL_DAYS=120
MAX_BATCH_DEVICES=20
BRIDGE_ALLOWED_ORIGINS=https://home-assistant.io,https://www.home-assistant.io

# Google OAuth client ID for token exchange
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Managed in Google Secret Manager and bound to functions:
# TOKEN_HASH_PEPPER
# GOOGLE_CLIENT_SECRET
